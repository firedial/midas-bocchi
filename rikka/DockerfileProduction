FROM alpine:3.23.3

RUN apk --update add tzdata && \
    cp /usr/share/zoneinfo/Asia/Tokyo /etc/localtime && \
    apk del tzdata && \
    rm -rf /var/cache/apk/*

RUN apk add mariadb-dev && \
    apk add mariadb-client && \
    apk add curl && \
    apk add openssl

RUN mkdir /mnt/nas

COPY ./rikka /app/
